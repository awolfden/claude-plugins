{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "title": "Claude Code Plugin",
  "description": "Schema for Claude Code plugin/skill definitions",
  "type": "object",
  "required": ["id", "name", "description", "version", "author", "type", "installation"],
  "properties": {
    "id": {
      "type": "string",
      "pattern": "^[a-z0-9-]+$",
      "description": "Unique identifier (lowercase, alphanumeric, hyphens)"
    },
    "name": {
      "type": "string",
      "minLength": 1,
      "maxLength": 50,
      "description": "Display name of the plugin"
    },
    "description": {
      "type": "string",
      "minLength": 10,
      "maxLength": 500,
      "description": "Brief description of what the plugin does"
    },
    "longDescription": {
      "type": "string",
      "description": "Detailed description with usage examples"
    },
    "version": {
      "type": "string",
      "pattern": "^\\d+\\.\\d+\\.\\d+$",
      "description": "Semantic version (e.g., 1.0.0)"
    },
    "author": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "github": { "type": "string" },
        "email": { "type": "string", "format": "email" }
      }
    },
    "type": {
      "type": "string",
      "enum": ["skill", "hook", "mcp-server", "prompt-template"],
      "description": "Type of Claude Code extension"
    },
    "categories": {
      "type": "array",
      "items": {
        "type": "string",
        "enum": [
          "productivity",
          "development",
          "git",
          "testing",
          "documentation",
          "ai",
          "utilities",
          "integrations",
          "code-quality",
          "devops"
        ]
      },
      "description": "Categories for filtering"
    },
    "tags": {
      "type": "array",
      "items": { "type": "string" },
      "description": "Additional searchable tags"
    },
    "repository": {
      "type": "string",
      "format": "uri",
      "description": "GitHub repository URL"
    },
    "homepage": {
      "type": "string",
      "format": "uri",
      "description": "Project homepage or documentation URL"
    },
    "installation": {
      "type": "object",
      "required": ["type"],
      "properties": {
        "type": {
          "type": "string",
          "enum": ["settings-json", "npm", "manual", "script"]
        },
        "command": {
          "type": "string",
          "description": "NPM install command if applicable"
        },
        "config": {
          "type": "object",
          "description": "Configuration to add to Claude Code settings"
        },
        "instructions": {
          "type": "string",
          "description": "Manual installation instructions"
        }
      }
    },
    "requirements": {
      "type": "object",
      "properties": {
        "claudeCodeVersion": {
          "type": "string",
          "description": "Minimum Claude Code version required"
        },
        "dependencies": {
          "type": "array",
          "items": { "type": "string" },
          "description": "External dependencies needed"
        },
        "platforms": {
          "type": "array",
          "items": {
            "type": "string",
            "enum": ["macos", "linux", "windows"]
          }
        }
      }
    },
    "screenshots": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "url": { "type": "string", "format": "uri" },
          "caption": { "type": "string" }
        }
      }
    },
    "license": {
      "type": "string",
      "description": "SPDX license identifier"
    },
    "createdAt": {
      "type": "string",
      "format": "date"
    },
    "updatedAt": {
      "type": "string",
      "format": "date"
    }
  }
}
